# Specrity Configuration
# Copy this file to .env and fill in your values

# ─── Jira 設定 ───

# Jira Cloud ID (選填 — 若未設定，會透過 MCP 自動偵測)
# 若有多個 Jira Cloud instance 才需要指定
JIRA_CLOUD_ID=

# 預設 Jira Project Key (選填 — 可從 ticket ID 如 HTGO2-123 自動解析)
# 僅在不帶 ticket ID 的操作時使用
JIRA_PROJECT_KEY=

# ─── Spec Sub-repo 設定 ───

# Spec Sub-repo 的絕對路徑 (必填，PRD 存放位置)
SPEC_REPO_PATH=

# Spec Sub-repo 的 Git remote URL (選填，用於自動 push)
SPEC_REPO_REMOTE=
